---
import Base from "@/layouts/Base.astro";

// Two-column article shell per homestem-spec: 1100px max page, 720px content
// column + 280px sticky sidebar, 40px gap. Sidebar collapses below the
// hero+intro on mobile. The `hero` slot spans full content width above the grid;
// the default slot is the article body; the `sidebar` slot is the sticky rail.
export interface Props {
  title?: string;
  meta_title?: string;
  description?: string;
  image?: string;
  noindex?: boolean;
  canonical?: string;
  jsonLd?: Record<string, any>[];
}

const { jsonLd = [], ...seo } = Astro.props;
const hasSidebar = Astro.slots.has("sidebar");
---

<Base {...seo}>
  {
    jsonLd.map((schema) => (
      <script
        is:inline
        type="application/ld+json"
        set:html={JSON.stringify(schema)}
        slot="head"
      />
    ))
  }
  <article class="hs-article">
    {
      Astro.slots.has("hero") && (
        <div class="hs-article__hero">
          <slot name="hero" />
        </div>
      )
    }
    <div class={`hs-article__grid${hasSidebar ? "" : " hs-article__grid--single"}`}>
      <div class="hs-article__content">
        <slot />
      </div>
      {
        hasSidebar && (
          <aside class="hs-article__sidebar">
            <div class="hs-article__sidebar-inner">
              <slot name="sidebar" />
            </div>
          </aside>
        )
      }
    </div>
  </article>
</Base>

<style>
  .hs-article {
    max-width: var(--page-width);
    margin-inline: auto;
    padding-inline: var(--page-padding);
    padding-block: var(--space-7);
  }

  .hs-article__hero {
    /* Break out of the article's page-padding so hero fills full 1100px */
    margin-inline: calc(-1 * var(--page-padding));
    margin-bottom: var(--space-6);
  }

  .hs-article__grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr) var(--sidebar-width);
    gap: var(--layout-gap);
    align-items: start;
  }

  .hs-article__grid--single {
    grid-template-columns: minmax(0, var(--content-width));
    justify-content: center;
  }

  .hs-article__content {
    max-width: var(--content-width);
    min-width: 0;
    justify-self: end;
    width: 100%;
  }

  .hs-article__sidebar {
    width: var(--sidebar-width);
  }

  .hs-article__sidebar-inner {
    position: sticky;
    top: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
  }

  /* Below 1024px the sidebar drops below the hero, ahead of the content —
     the closest CSS-only approximation of "below hero+intro, before the
     first product" since intro and product blocks both live in the same
     MDX-authored content slot and can't be split by the layout itself. */
  @media (max-width: 1023px) {
    .hs-article__grid {
      grid-template-columns: minmax(0, 1fr);
    }
    .hs-article__content {
      justify-self: stretch;
      margin-inline: auto;
      order: 2;
    }
    .hs-article__sidebar {
      width: 100%;
      max-width: var(--content-width);
      margin-inline: auto;
      order: 1;
    }
    .hs-article__sidebar-inner {
      position: static;
    }
  }
</style>
