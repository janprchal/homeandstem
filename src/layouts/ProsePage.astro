---
import Base from "@/layouts/Base.astro";
import config from "@/config/config.json";

// Simple centered text page for About / legal content.
export interface Props {
  title: string;
  description?: string;
  updated?: string;
  path: string;
}
const { title, description, updated, path } = Astro.props;
---

<Base
  title={title}
  description={description}
  canonical={`${config.site.base_url}${path}`}
>
  <article class="hs-prose">
    <h1>{title}</h1>
    {updated && <p class="hs-prose__updated">Last updated: {updated}</p>}
    <slot />
  </article>
</Base>

<style>
  .hs-prose {
    max-width: var(--content-width);
    margin-inline: auto;
    padding: var(--space-7) var(--page-padding);
  }
  .hs-prose :global(h1) {
    font-size: clamp(28px, 4vw, 38px);
    margin-bottom: var(--space-4);
  }
  .hs-prose :global(h2) {
    font-size: 24px;
    margin-top: var(--space-7);
    margin-bottom: var(--space-3);
  }
  .hs-prose :global(p),
  .hs-prose :global(li) {
    font-size: 17px;
    line-height: var(--line-height-body);
    color: var(--color-text-secondary);
  }
  .hs-prose :global(p),
  .hs-prose :global(ul),
  .hs-prose :global(ol) {
    margin-bottom: var(--space-4);
  }
  .hs-prose :global(ul),
  .hs-prose :global(ol) {
    padding-left: var(--space-5);
  }
  .hs-prose :global(a) {
    color: var(--color-primary);
    text-decoration: underline;
  }
  .hs-prose__updated {
    color: var(--color-text-muted) !important;
    font-family: var(--font-heading);
    font-size: var(--font-size-label) !important;
  }
</style>
