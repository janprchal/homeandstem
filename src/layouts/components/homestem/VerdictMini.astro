---
import AffiliateLink from "@/components/homestem/AffiliateLink.astro";

// Sidebar verdict widget for comparison articles. Shows BOTH products with CTAs
// always visible while reading. Replaces EditorsPick in this article type.
interface MiniProduct {
  name: string;
  image: string;
  imageAlt: string;
  affiliateUrl: string;
}
export interface Props {
  productA?: MiniProduct;
  productB?: MiniProduct;
}
const { productA, productB } = Astro.props;
const products = [productA, productB].filter(
  (p): p is MiniProduct => p !== undefined,
);
---

{
  products.length > 0 && (
    <div class="hs-vmini">
      <span class="hs-vmini__label">Quick Verdict</span>
      {products.map((p, i) => (
        <div class="hs-vmini__item">
          <div class="hs-vmini__row">
            <img
              src={p.image}
              alt={p.imageAlt}
              width="56"
              height="56"
              loading="lazy"
            />
            <span class="hs-vmini__name">{p.name}</span>
          </div>
          <AffiliateLink
            href={p.affiliateUrl}
            product={p.name}
            class="hs-btn hs-btn--primary hs-btn--block"
          >
            Check price →
          </AffiliateLink>
          {i < products.length - 1 && (
            <div class="hs-vmini__divider" aria-hidden="true">vs</div>
          )}
        </div>
      ))}
    </div>
  )
}

<style>
  .hs-vmini {
    background-color: var(--color-primary-bg);
    border-left: 3px solid var(--color-primary);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .hs-vmini__label {
    font-family: var(--font-heading);
    font-size: var(--font-size-micro);
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-wide);
    color: var(--color-primary);
    font-weight: var(--font-weight-bold);
  }

  .hs-vmini__item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .hs-vmini__row {
    display: flex;
    gap: var(--space-3);
    align-items: center;
  }

  .hs-vmini__row img {
    width: 56px;
    height: 56px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    flex-shrink: 0;
  }

  .hs-vmini__name {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-caption);
    color: var(--color-text-primary);
    line-height: var(--line-height-tight);
  }

  .hs-vmini__divider {
    text-align: center;
    font-family: var(--font-heading);
    font-weight: var(--font-weight-bold);
    font-size: var(--font-size-label-sm);
    color: var(--color-text-muted);
    padding: var(--space-1) 0;
    border-top: 1px solid var(--color-border);
    border-bottom: 1px solid var(--color-border);
    margin-block: var(--space-1);
  }
</style>
