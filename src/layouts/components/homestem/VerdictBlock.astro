---
import AffiliateLink from "@/components/homestem/AffiliateLink.astro";

interface Verdict {
  name: string;
  affiliateUrl: string;
  buyIfReasons: string[];
}
export interface Props {
  productA: Verdict;
  productB: Verdict;
}
const { productA, productB } = Astro.props;
const products = [productA, productB];
---

<div class="hs-verdictblock">
  {
    products.map((p) => (
      <div class="hs-vb hs-card">
        <h3 class="hs-vb__title">Buy the {p.name} if…</h3>
        <ul>
          {p.buyIfReasons.map((r) => (
            <li>{r}</li>
          ))}
        </ul>
        <AffiliateLink
          href={p.affiliateUrl}
          product={p.name}
          class="hs-btn hs-btn--primary hs-btn--block"
        >
          Check price on Amazon →
        </AffiliateLink>
      </div>
    ))
  }
</div>

<style>
  .hs-verdictblock {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4);
    margin-block: var(--space-6);
  }
  .hs-vb {
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .hs-vb__title {
    margin: 0;
    font-size: var(--font-size-h4);
  }
  .hs-vb ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    flex-grow: 1;
  }
  .hs-vb li {
    position: relative;
    padding-left: var(--space-5);
    font-size: var(--font-size-body-sm);
    color: var(--color-text-secondary);
  }
  .hs-vb li::before {
    content: "✓";
    position: absolute;
    left: 0;
    color: var(--color-primary);
    font-weight: var(--font-weight-bold);
  }
  @media (max-width: 600px) {
    .hs-verdictblock {
      grid-template-columns: 1fr;
    }
  }
</style>
