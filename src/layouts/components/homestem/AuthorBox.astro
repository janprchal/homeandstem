---
// E-E-A-T author signal at the end of every article.
export interface Props {
  name: string;
  avatar?: string;
  bio: string;
}
const { name, avatar, bio } = Astro.props;
---

<div class="hs-author hs-card">
  {
    avatar && (
      <img src={avatar} alt={name} width="64" height="64" loading="lazy" />
    )
  }
  <div>
    <div class="hs-author__name">{name}</div>
    <p class="hs-author__bio">{bio}</p>
  </div>
</div>

<style>
  .hs-author {
    display: flex;
    gap: var(--space-4);
    align-items: center;
    padding: var(--space-4);
    margin-block: var(--space-6);
  }
  .hs-author img {
    width: 64px;
    height: 64px;
    border-radius: var(--radius-full);
    object-fit: cover;
    flex-shrink: 0;
  }
  .hs-author__name {
    font-family: var(--font-heading);
    font-weight: var(--font-weight-bold);
    color: var(--color-text-primary);
  }
  .hs-author__bio {
    margin: var(--space-1) 0 0;
    font-size: var(--font-size-label);
    color: var(--color-text-secondary);
    line-height: var(--line-height-snug);
  }
</style>
