---
import config from "@/config/config.json";
import menu from "@/config/menu.json";
import Logo from "@/components/homestem/Logo.astro";

const year = new Date().getFullYear();
const exploreLinks = menu.main.filter((item) => item.url.startsWith("/category/"));
const legalLinks = menu.footer;
const { email } = config.contactinfo;
---

<footer class="hs-footer">
  <div class="hs-footer__inner">

    <!-- Brand column -->
    <div class="hs-footer__brand">
      <a href="/" class="hs-footer__logo" aria-label="HomeStem home">
        <Logo />
      </a>
      <p class="hs-footer__tagline">
        Tested home &amp; garden guides for the hands-on homeowner.
      </p>
      <p class="hs-footer__disclaimer">
        As an Amazon Associate, HomeStem earns from qualifying purchases. We may
        earn a commission when you buy through links on our site, at no extra
        cost to you.
      </p>
      <a
        href="https://www.pinterest.com/homeandstem/"
        class="hs-footer__pinterest"
        aria-label="Follow HomeStem on Pinterest"
        target="_blank"
        rel="noopener noreferrer"
      >
        <!-- Pinterest P icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.373 0 0 5.373 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 0 1 .083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.632-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0z"
          />
        </svg>
        Follow on Pinterest
      </a>
      <a href={`mailto:${email}`} class="hs-footer__email">{email}</a>
    </div>

    <!-- Explore column -->
    <nav class="hs-footer__col" aria-label="Explore categories">
      <h3 class="hs-footer__col-heading">Explore</h3>
      <ul class="hs-footer__links">
        {
          exploreLinks.map((item) => (
            <li>
              <a href={item.url} class="hs-footer__link">{item.name}</a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Legal column -->
    <nav class="hs-footer__col" aria-label="Legal and about">
      <h3 class="hs-footer__col-heading">Legal</h3>
      <ul class="hs-footer__links">
        {
          legalLinks.map((item) => (
            <li>
              <a href={item.url} class="hs-footer__link">{item.name}</a>
            </li>
          ))
        }
      </ul>
    </nav>

  </div>

  <!-- Bottom bar -->
  <div class="hs-footer__bottom">
    <p class="hs-footer__copyright">
      &copy; {year} HomeStem. All rights reserved.
    </p>
  </div>
</footer>

<style>
  .hs-footer {
    background-color: var(--color-bg-subtle);
    border-top: 1px solid var(--color-border);
  }

  .hs-footer__inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding: var(--space-7) var(--page-padding) var(--space-6);
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: var(--space-8);
    align-items: start;
  }

  /* Brand column */
  .hs-footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 300px;
  }

  .hs-footer__logo {
    display: inline-flex;
    align-items: center;
    text-decoration: none;
  }

  .hs-footer__tagline {
    font-family: var(--font-heading);
    font-size: var(--font-size-label);
    color: var(--color-text-secondary);
    line-height: var(--line-height-snug);
    margin: 0;
  }

  .hs-footer__disclaimer {
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    line-height: var(--line-height-snug);
    margin: 0;
  }

  .hs-footer__pinterest {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-heading);
    font-size: var(--font-size-label-sm);
    font-weight: 600;
    color: #e60023;
    text-decoration: none;
    margin-top: var(--space-1);
  }
  .hs-footer__pinterest:hover {
    text-decoration: underline;
  }

  .hs-footer__email {
    font-family: var(--font-heading);
    font-size: var(--font-size-label-sm);
    color: var(--color-text-secondary);
    text-decoration: none;
  }
  .hs-footer__email:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  /* Nav columns */
  .hs-footer__col {
    min-width: 140px;
  }

  .hs-footer__col-heading {
    font-family: var(--font-heading);
    font-size: var(--font-size-label-sm);
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: var(--letter-spacing-caps);
    color: var(--color-text-muted);
    margin: 0 0 var(--space-3);
  }

  .hs-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .hs-footer__link {
    font-family: var(--font-heading);
    font-size: var(--font-size-label);
    color: var(--color-text-secondary);
    text-decoration: none;
    line-height: var(--line-height-snug);
  }
  .hs-footer__link:hover {
    color: var(--color-primary);
  }

  /* Bottom bar */
  .hs-footer__bottom {
    max-width: var(--page-width);
    margin-inline: auto;
    padding: var(--space-4) var(--page-padding);
    border-top: 1px solid var(--color-border);
  }

  .hs-footer__copyright {
    font-family: var(--font-heading);
    font-size: var(--font-size-caption);
    color: var(--color-text-muted);
    margin: 0;
  }

  /* Mobile */
  @media (max-width: 1023px) {
    .hs-footer__inner {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-6);
    }

    .hs-footer__brand {
      grid-column: 1 / -1;
      max-width: none;
    }
  }

  @media (max-width: 599px) {
    .hs-footer__inner {
      grid-template-columns: 1fr;
    }
  }
</style>
