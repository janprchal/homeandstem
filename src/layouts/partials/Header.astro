---
import menu from "@/config/menu.json";
import Logo from "@/components/homestem/Logo.astro";

const { main } = menu;
---

<header class="hs-header">
  <div class="hs-header__inner">
    <!-- Logo -->
    <a href="/" class="hs-header__logo" aria-label="HomeStem home">
      <Logo />
    </a>

    <!-- Main nav -->
    <nav class="hs-header__nav" id="hs-header-nav" aria-label="Main navigation">
      <ul class="hs-header__links">
        {
          main.map((item) => (
            <li>
              <a href={item.url} class="hs-header__link">
                {item.name}
              </a>
            </li>
          ))
        }
      </ul>
    </nav>

    <!-- Right side: search + mobile burger -->
    <div class="hs-header__end">
      <a href="/search" class="hs-header__search" aria-label="Search">
        <!-- Search icon -->
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="11" cy="11" r="8"></circle>
          <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
      </a>

      <button
        class="hs-header__burger"
        id="hs-burger"
        aria-expanded="false"
        aria-controls="hs-header-nav"
        aria-label="Toggle navigation"
        type="button"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
          class="hs-header__burger-icon hs-header__burger-icon--open"
        >
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="22"
          height="22"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          aria-hidden="true"
          class="hs-header__burger-icon hs-header__burger-icon--close"
        >
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  // View Transitions re-executes module scripts on every navigation.
  // Guard with a window flag so we only register document listeners once.
  if (!(window as any).__hsHeader) {
    (window as any).__hsHeader = true;

    // Reset nav to closed before every page swap so stale open state never carries over.
    document.addEventListener("astro:before-preparation", () => {
      document.getElementById("hs-header-nav")?.classList.remove("hs-header__nav--open");
      document.getElementById("hs-burger")?.setAttribute("aria-expanded", "false");
    });

    // Re-bind burger after every page swap. cloneNode strips any stale listeners
    // that accumulated on the element before this guard was in place.
    document.addEventListener("astro:page-load", () => {
      const burger = document.getElementById("hs-burger");
      const nav = document.getElementById("hs-header-nav");
      if (!burger || !nav) return;
      const fresh = burger.cloneNode(true) as HTMLButtonElement;
      burger.replaceWith(fresh);
      fresh.addEventListener("click", () => {
        const open = fresh.getAttribute("aria-expanded") === "true";
        fresh.setAttribute("aria-expanded", String(!open));
        nav.classList.toggle("hs-header__nav--open");
      });
    });
  }
</script>

<style>
  .hs-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background-color: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border);
  }

  .hs-header__inner {
    max-width: var(--page-width);
    margin-inline: auto;
    padding: 0 var(--page-padding);
    height: 64px;
    display: flex;
    align-items: center;
    gap: var(--space-6);
  }

  /* Logo */
  .hs-header__logo {
    display: flex;
    align-items: center;
    text-decoration: none;
    flex-shrink: 0;
  }

  /* Nav */
  .hs-header__nav {
    margin-left: auto;
  }

  .hs-header__links {
    display: flex;
    align-items: center;
    gap: var(--space-1);
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .hs-header__link {
    display: block;
    padding: var(--space-2) var(--space-3);
    font-family: var(--font-heading);
    font-size: var(--font-size-label);
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .hs-header__link:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-bg);
  }

  /* Right side */
  .hs-header__end {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-shrink: 0;
  }

  .hs-header__search {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-text-secondary);
    border-radius: var(--radius-sm);
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .hs-header__search:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-bg);
  }

  /* Burger button */
  .hs-header__burger {
    display: none;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    color: var(--color-text-secondary);
    background: none;
    border: none;
    cursor: pointer;
    border-radius: var(--radius-sm);
    padding: 0;
    transition: color 0.15s ease, background-color 0.15s ease;
  }
  .hs-header__burger:hover {
    color: var(--color-primary);
    background-color: var(--color-primary-bg);
  }

  /* Show close icon only when menu is open */
  .hs-header__burger-icon--close {
    display: none;
  }
  .hs-header__burger[aria-expanded="true"] .hs-header__burger-icon--open {
    display: none;
  }
  .hs-header__burger[aria-expanded="true"] .hs-header__burger-icon--close {
    display: block;
  }

  /* Mobile */
  @media (max-width: 1023px) {
    .hs-header__inner {
      position: relative;
    }

    .hs-header__end {
      margin-left: auto;
    }

    .hs-header__nav {
      display: none;
      position: absolute;
      top: 100%;
      left: 0;
      right: 0;
      background-color: var(--color-bg-card);
      border-top: 1px solid var(--color-border);
      border-bottom: 1px solid var(--color-border);
      padding: var(--space-3) var(--page-padding);
    }

    .hs-header__nav--open {
      display: block;
    }

    .hs-header__links {
      flex-direction: column;
      align-items: stretch;
      gap: 0;
    }

    .hs-header__link {
      padding: var(--space-3) var(--space-2);
      border-radius: 0;
      border-bottom: 1px solid var(--color-border);
      font-size: var(--font-size-body-sm);
    }
    .hs-header__links li:last-child .hs-header__link {
      border-bottom: none;
    }

    .hs-header__burger {
      display: flex;
    }
  }
</style>
