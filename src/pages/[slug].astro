---
import ArticleLayout from "@/layouts/ArticleLayout.astro";
import { sortByPubDate } from "@/lib/articleCard";
import { getCollection, render } from "astro:content";

// Article route: /[slug]. Static pages (about, legal, contact) are their own
// .astro files, so this route serves only the `articles` collection.
export async function getStaticPaths() {
  const articles = await getCollection(
    "articles",
    ({ data }) => import.meta.env.DEV || !data.draft,
  );

  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article, articles },
  }));
}

const { article, articles } = Astro.props;
const { Content, headings } = await render(article);

const related = sortByPubDate(
  articles.filter(
    (a) => a.id !== article.id && a.data.category === article.data.category,
  ),
)
  .slice(0, 3)
  .map((a) => ({
    title: a.data.title,
    slug: a.id,
    image: a.data.heroImage.src,
    imageAlt: a.data.heroImageAlt,
    category: a.data.category,
  }));
---

<ArticleLayout
  article={article}
  headings={headings}
  related={related}
  heroSrc={article.data.heroImage.src}
>
  <Content />
</ArticleLayout>
